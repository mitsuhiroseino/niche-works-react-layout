{
  "name": "@niche-works/react-layout",
  "version": "0.3.0",
  "private": true,
  "keywords": [
    "react",
    "layout",
    "style"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mitsuhiroseino/niche-works-react-layout.git"
  },
  "license": "MIT",
  "author": "Mitsuhiro Seino",
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*/index.ts",
    "./constants": "./src/constants.ts",
    "./*/constants": "./src/*/constants.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "scripts": {
    "build": "tsdown",
    "build-storybook": "storybook build",
    "check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "indexes": "tsx scripts/indexes.ts",
    "storybook": "storybook dev -p 6006",
    "test": "echo \"Error: no test specified\" && exit 1",
    "tidy": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\" --config ./prettier.tidy.config.ts"
  },
  "dependencies": {
    "@niche-works/react": "^0.1.0",
    "@niche-works/react-style-proxy": "^0.1.0",
    "@niche-works/types": "^0.1.0",
    "@niche-works/utils": "^0.1.3",
    "clsx": "^2.1.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@chromatic-com/storybook": "^5.1.2",
    "@emotion/babel-plugin": "^11.13.5",
    "@emotion/css": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@eslint/js": "^10.0.1",
    "@niche-works/dev": "^0.5.1",
    "@niche-works/react-parts-props": "^0.1.0",
    "@niche-works/react-style-props": "^0.1.2",
    "@niche-works/rollup-plugin-dist-package": "^0.1.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@testing-library/react": "^16.3.2",
    "@types/babel__core": "^7.20.5",
    "@types/chroma-js": "^3.1.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "chroma-js": "^3.2.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.5",
    "fast-glob": "^3.3.3",
    "globals": "^17.5.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "re-resizable": "^6.11.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^6.1.3",
    "rollup-plugin-copy": "^3.5.0",
    "sass-embedded": "^1.99.0",
    "storybook": "^10.3.5",
    "tsdown": "^0.21.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "packageManager": "pnpm@10.32.1"
}
